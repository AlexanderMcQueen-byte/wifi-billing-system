NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/wifi_billing

# Safaricom Daraja API
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=your_consumer_key
DARAJA_CONSUMER_SECRET=your_consumer_secret
DARAJA_PASSKEY=your_passkey
DARAJA_SHORTCODE=174379
DARAJA_CALLBACK_URL=https://your-domain.com/api/callback
# Optional: a shared secret the Daraja callback can include as header `x-callback-secret` or query `?secret=` to verify authenticity
DARAJA_CALLBACK_SECRET=optional_shared_secret

# MikroTik RouterOS API
ROUTER_HOST=192.168.88.1
ROUTER_PORT=8728
ROUTER_USER=admin
ROUTER_PASSWORD=your_router_password
ROUTER_SECURE=false
