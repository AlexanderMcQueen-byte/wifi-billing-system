NODE_ENV=development
PORT=3000
# MongoDB Atlas connection string (required - no local fallback)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/wifi_billing

# Safaricom Daraja API
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=your_consumer_key
DARAJA_CONSUMER_SECRET=your_consumer_secret
DARAJA_PASSKEY=your_passkey
DARAJA_SHORTCODE=174379
DARAJA_CALLBACK_URL=https://your-domain.com/api/callback
# Optional: a shared secret the Daraja callback can include as header `x-callback-secret` or query `?secret=` to verify authenticity
DARAJA_CALLBACK_SECRET=optional_shared_secret

# MikroTik RouterOS API
ROUTER_HOST=192.168.88.1
ROUTER_PORT=8728
ROUTER_USER=admin
ROUTER_PASSWORD=your_router_password
ROUTER_SECURE=false

# Cloudflare KV and Turnstile configuration
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_KV_NAMESPACE_ID=your_cloudflare_kv_namespace_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
